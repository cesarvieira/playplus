{
  "name": "@playplus/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#config/*": {
      "development": "./src/config/*.ts",
      "default": "./dist/config/*.js"
    },
    "#http/*": {
      "development": "./src/http/*.ts",
      "default": "./dist/http/*.js"
    },
    "#infra/*": {
      "development": "./src/infra/*.ts",
      "default": "./dist/infra/*.js"
    },
    "#modules/*": {
      "development": "./src/modules/*.ts",
      "default": "./dist/modules/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --inspect=9229 --watch --use-system-ca --conditions=development --env-file=../../.env src/server.ts",
    "start": "node --env-file=../../.env dist/server.js",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "node --env-file=../../.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=../../.env ./node_modules/drizzle-kit/bin.cjs migrate && node --conditions=development --env-file=../../.env src/infra/database/seed/run.ts",
    "db:seed": "node --conditions=development --env-file=../../.env src/infra/database/seed/run.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1079.0",
    "@aws-sdk/s3-request-presigner": "3.1079.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.3.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/websocket": "^11.2.0",
    "@node-rs/argon2": "^2.0.2",
    "@playplus/shared": "workspace:*",
    "bullmq": "^5.80.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.5",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
    "pino": "10.3.1",
    "postgres": "^3.4.8",
    "slugify": "^1.6.9",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.0",
    "drizzle-kit": "^0.31.9",
    "pino-pretty": "^13.1.3"
  }
}
