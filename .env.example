# Play+ — variáveis de ambiente (desenvolvimento local)
# Copie para .env e ajuste valores sensíveis: cp .env.example .env
# Apps (api, worker) rodam fora do Docker nesta fase — use localhost nas URLs.

# --- Banco de dados (PostgreSQL via docker compose) ---
# Consumidor futuro: api, worker
DATABASE_URL=postgresql://playplus:playplus@localhost:5432/playplus

# --- Fila / cache (Valkey via docker compose) ---
# Consumidor futuro: api, worker
VALKEY_URL=redis://localhost:6379

# --- Storage S3-compatible (MinIO em dev; Cloudflare R2 em prod) ---
# Consumidor futuro: api, worker
# Troca MinIO ↔ R2 somente por estas variáveis — nenhuma mudança de código.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=playplus
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1

# --- Video / CDN ---
# Consumidor: api
# Opcionais em dev — omitir usa os defaults abaixo
CDN_BASE_URL=http://localhost:8080/media
PRESIGNED_UPLOAD_TTL_SECONDS=3600

# --- JWT (autenticação) ---
# Consumidor futuro: api
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# --- Usuário admin seed (migration inicial) ---
# Consumidor futuro: api
ADMIN_SEED_EMAIL=admin@playplus.localhost
ADMIN_SEED_PASSWORD=change-me-locally

# --- API runtime ---
# Consumidor futuro: api
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development

# --- Cookies (refresh token) ---
# Consumidor: api
# Dev HTTP (pnpm dev):
#  COOKIE_SECURE=false
#  COOKIE_SAME_SITE=lax
#  COOKIE_DOMAIN vazio
# Dev HTTPS (pnpm dev:https):
#  COOKIE_SECURE=true
#  COOKIE_SAME_SITE=none
#  COOKIE_DOMAIN=api.playplus.localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

# --- Auth SSR + M2M (ADR-006) ---
# Consumidor: api, apps/admin (server-only no admin)
# Dev HTTP: CORS_ADMIN_ORIGIN=http://localhost:3001
# Dev HTTPS: CORS_ADMIN_ORIGIN=https://admin.playplus.localhost:3001
M2M_SERVICE_TOKEN=change-me-to-a-random-m2m-token-at-least-32-chars
DELEGATION_JWT_SECRET=change-me-to-another-random-string-at-least-32-chars
DELEGATION_JWT_TTL_SECONDS=60
CORS_ADMIN_ORIGIN=

# --- TLS local (mkcert) — obrigatório para pnpm dev:https ---
# Caminhos relativos à raiz do repositório. Gere com mkcert — veja README.
# DEV_TLS_CERT=certs/playplus.pem
# DEV_TLS_KEY=certs/playplus-key.pem

# --- Admin (Nuxt) ---
# Consumidor: apps/admin
# Dev HTTP:
NUXT_PUBLIC_API_URL=http://localhost:3000/v1
NUXT_PUBLIC_WS_URL=ws://localhost:3000/ws
NUXT_PUBLIC_WEB_URL=http://localhost:3001
# Dev HTTPS (descomente junto com TLS e cookies acima):
# NUXT_PUBLIC_API_URL=https://api.playplus.localhost:3000/v1
# NUXT_PUBLIC_WS_URL=wss://api.playplus.localhost:3000/ws
# NUXT_PUBLIC_WEB_URL=https://admin.playplus.localhost:3001
