# Play+ — variáveis de ambiente (desenvolvimento local)
# Copie para .env e ajuste valores sensíveis: cp .env.example .env
# Apps (api, worker) rodam no host — use localhost nas URLs. Infra (postgres, valkey, minio) via Docker Compose.

# --- Banco de dados (PostgreSQL via docker compose) ---
# Consumidor: api, worker
DATABASE_URL=postgresql://playplus:playplus@localhost:5432/playplus

# --- Fila / cache (Valkey via docker compose) ---
# Consumidor: api, worker
VALKEY_URL=redis://localhost:6379

# --- Storage S3-compatible (MinIO em dev; Cloudflare R2 em prod) ---
# Consumidor: api, worker, apps/admin (CSP connect-src via STORAGE_ENDPOINT)
# Troca MinIO ↔ R2 somente por estas variáveis — nenhuma mudança de código.
# Dev HTTPS (Caddy termina TLS; MinIO servido por storage.playplus.localhost, sem porta):
# STORAGE_ENDPOINT=https://storage.playplus.localhost
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=playplus
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1

# --- Video / CDN ---
# Consumidor: api
# Opcionais em dev — omitir usa os defaults abaixo
CDN_BASE_URL=http://localhost:8080/media
PRESIGNED_UPLOAD_TTL_SECONDS=3600

# --- JWT (autenticação) ---
# Consumidor futuro: api
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# --- Usuário admin seed (migration inicial) ---
# Consumidor futuro: api
ADMIN_SEED_EMAIL=admin@playplus.localhost
ADMIN_SEED_PASSWORD=change-me-locally

# --- API runtime ---
# Consumidor futuro: api
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development

# --- Worker / FFmpeg ---
# Consumidor: packages/worker
# Opcional — default: ffmpeg no PATH
# FFMPEG_PATH=C:\Users\...\scoop\shims\ffmpeg.exe

# --- Cookies (refresh token) ---
# Consumidor: api
# Dev HTTP (pnpm dev):
#  COOKIE_SECURE=false
#  COOKIE_SAME_SITE=lax
#  COOKIE_DOMAIN vazio
# Dev HTTPS (Caddy):
#  COOKIE_SECURE=true
#  COOKIE_SAME_SITE=none
#  COOKIE_DOMAIN=api.playplus.localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

# --- Auth SSR + M2M (ADR-006) ---
# Consumidor: api, apps/admin (server-only no admin)
# Dev HTTP: CORS_ADMIN_ORIGIN=http://localhost:3002
# Dev HTTPS (Caddy, sem porta): CORS_ADMIN_ORIGIN=https://admin.playplus.localhost
M2M_SERVICE_TOKEN=change-me-to-a-random-m2m-token-at-least-32-chars
DELEGATION_JWT_SECRET=change-me-to-another-random-string-at-least-32-chars
DELEGATION_JWT_TTL_SECONDS=60
CORS_ADMIN_ORIGIN=

# --- TLS local (mkcert) ---
# No modo Caddy o TLS é terminado pelo proxy, que lê os certificados direto de
# ./certs (montados no container — veja docker-compose.yml). Os apps Node NÃO
# precisam de DEV_TLS_* neste modo; mantenha comentado para a API servir HTTP
# atrás do Caddy. Gere os certs com mkcert — veja README.
# DEV_TLS_CERT=certs/playplus.pem
# DEV_TLS_KEY=certs/playplus-key.pem

# --- Frontends Nuxt (admin + web) ---
# Consumidores: apps/admin (porta 3002) e apps/web (porta 3001)
#
# NUXT_PUBLIC_API_URL / NUXT_PUBLIC_WS_URL — API e WebSocket vistos pelo BROWSER.
#   No modo Caddy apontam para os hostnames sem porta (o proxy resolve a porta).
#
# NUXT_API_INTERNAL_BASE_URL — base usada apenas no SSR (server-to-server).
#   Fala direto com a API por HTTP no loopback, sem passar pelo Caddy nem TLS.
#   Default (se omitida): http://127.0.0.1:3000/v1
#
# NUXT_PUBLIC_WEB_URL — URL base do viewer (apps/web), NÃO do admin.
#   • admin → runtimeConfig.public.webUrl (links "assistir" no catálogo)
#   • web   → runtimeConfig.public.siteUrl (URL canônica do próprio app)
#
# Dev HTTP (pnpm dev, sem proxy):
NUXT_PUBLIC_API_URL=http://localhost:3000/v1
NUXT_PUBLIC_WS_URL=ws://localhost:3000/v1/ws
NUXT_PUBLIC_WEB_URL=http://localhost:3001
NUXT_API_INTERNAL_BASE_URL=http://127.0.0.1:3000/v1
# Dev HTTPS via Caddy (descomente junto com TLS/cookies acima; portas somem):
# STORAGE_ENDPOINT=https://storage.playplus.localhost
# NUXT_PUBLIC_API_URL=https://api.playplus.localhost/v1
# NUXT_PUBLIC_WS_URL=wss://api.playplus.localhost/v1/ws
# NUXT_PUBLIC_WEB_URL=https://web.playplus.localhost
# NUXT_API_INTERNAL_BASE_URL=http://127.0.0.1:3000/v1
