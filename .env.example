# Play+ — variáveis de ambiente (desenvolvimento local)
# Copie para .env e ajuste valores sensíveis: cp .env.example .env
# Apps (api, worker) rodam fora do Docker nesta fase — use localhost nas URLs.

# --- Banco de dados (PostgreSQL via docker compose) ---
# Consumidor futuro: api, worker
DATABASE_URL=postgresql://playplus:playplus@localhost:5432/playplus

# --- Fila / cache (Valkey via docker compose) ---
# Consumidor futuro: api, worker
VALKEY_URL=redis://localhost:6379

# --- Storage S3-compatible (MinIO em dev; Cloudflare R2 em prod) ---
# Consumidor futuro: api, worker
# Troca MinIO ↔ R2 somente por estas variáveis — nenhuma mudança de código.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=playplus
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1

# --- JWT (autenticação) ---
# Consumidor futuro: api
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# --- Usuário admin seed (migration inicial) ---
# Consumidor futuro: api
ADMIN_SEED_EMAIL=admin@playplus.local
ADMIN_SEED_PASSWORD=change-me-locally

# --- API runtime ---
# Consumidor futuro: api
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development

# --- Cookies (refresh token) ---
# Consumidor futuro: api
# Dev: COOKIE_SECURE=false, COOKIE_SAME_SITE=lax
# Prod: COOKIE_SECURE=true, COOKIE_SAME_SITE=strict
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
