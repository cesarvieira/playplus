{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {},
    "apps/api": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/admin": {
      "entry": [],
      "project": ["app/**/*.{ts,vue}"]
    },
    "apps/web": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/*": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreDependencies": ["lint-staged", "pino-pretty"]
}
