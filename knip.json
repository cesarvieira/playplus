{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreUnresolved": ["./src/test/setup-env.ts"],
  "workspaces": {
    ".": {
      "vitest": {
        "config": ["vitest.shared.node.ts", "vitest.shared.nuxt.ts", "apps/*/vitest.config.ts"]
      }
    },
    "apps/api": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/admin": {
      "project": ["app/**/*.{ts,vue}", "server/**/*.ts"],
      "ignore": ["app/components/PlSkeleton.vue"]
    },
    "apps/web": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/*": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreDependencies": ["eslint-flat-config-utils", "lint-staged", "pino-pretty"]
}
