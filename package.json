{
  "name": "playplus",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "packageExtensions": {
      "drizzle-kit": {
        "dependencies": {
          "drizzle-orm": "*",
          "postgres": "*"
        }
      }
    }
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint & eslint . --max-warnings 0",
    "typecheck": "turbo run typecheck",
    "knip": "knip",
    "format": "prettier --write \"**/*.{json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{json,md,yml,yaml}\"",
    "prepare": "husky",
    "pre-commit": "node scripts/pre-commit.mjs",
    "db:migrate": "pnpm --filter @playplus/api db:migrate"
  },
  "devDependencies": {
    "@awmottaz/prettier-plugin-void-html": "^2.1.0",
    "@eslint/config-helpers": "^0.6.0",
    "@eslint/js": "^9.28.0",
    "@eslint/json": "^2.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^20.0.2",
    "husky": "^9.1.7",
    "knip": "^6.24.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9",
    "vitest-environment-nuxt": "^2.0.0",
    "vue-eslint-parser": "^10.4.1"
  }
}
