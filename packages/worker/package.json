{
  "name": "@playplus/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --inspect=9230 --watch --use-system-ca --env-file=../../.env src/index.ts",
    "start": "node --env-file=../../.env dist/index.js",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@playplus/shared": "workspace:*",
    "bullmq": "^5.79.0",
    "ioredis": "^5.9.3",
    "pino": "10.3.1",
    "postgres": "^3.4.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "pino-pretty": "^13.1.3"
  }
}
